generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  schemas   = ["public", "auth"]
}

model StorySeries {
  id                Int                  @id @default(autoincrement())
  name              String
  created_at        DateTime             @default(now())
  storySeriesStories StorySeriesStories[]

  @@map("Story_Series")
  @@schema("public")
}

model StorySeriesStories {
  id              Int         @id @default(autoincrement())
  story_id        Int
  story_series_id Int
  created_at      DateTime    @default(now())
  story           Stories     @relation(fields: [story_id], references: [id])
  series          StorySeries @relation(fields: [story_series_id], references: [id])

  @@unique([story_id, story_series_id])
  @@map("Story_Series_Stories")
  @@schema("public")
}

model Stories {
  id        Int      @id @default(autoincrement())
  photo_url String?
  duration Int?
  status    Boolean  @default(true)
  created_at DateTime @default(now())
  storySeriesStories StorySeriesStories[]
  storyCategories StoryCategories[]
  storyTranslations StoryTranslations[]
  playlistStories PlaylistStories[]
  favorites Favorites[]

  @@map("Stories")
  @@schema("public")
}

model User {
  id                String    @id @db.Uuid
  email             String?
  phone             String?
  role              String?
  created_at        DateTime?
  updated_at        DateTime?
  last_sign_in_at   DateTime?
  app_metadata      Json      @default("{}") @map("raw_app_meta_data")
  user_metadata     Json      @default("{}") @map("raw_user_meta_data")
  profiles          Profiles[]

  @@map("users")
  @@schema("auth")
}

model Profiles {
  id        Int      @id @default(autoincrement())
  user_id    String   @db.Uuid
  name String
  date_of_birth DateTime? @db.Date
  gender Boolean
  photo_url String?
  created_at DateTime @default(now())
  user              User               @relation(fields: [user_id], references: [id])
  profileCategories ProfileCategories[]
  playlists Playlists[]
  favorites Favorites[]

  @@map("Profiles")
  @@schema("public")
}

model Categories {
  id        Int      @id @default(autoincrement())
  photo_url String?
  status    Boolean  @default(true)
  created_at DateTime @default(now())
  profileCategories ProfileCategories[]
  storyCategories StoryCategories[]
  categoryTranslations CategoryTranslations[]

  @@map("Categories")
  @@schema("public")
}

model Languages {
  id        Int      @id @default(autoincrement())
  name String
  country_code String
  created_at DateTime @default(now())
  storyTranslations StoryTranslations[]
  categoryTranslations CategoryTranslations[]

  @@map("Languages")
  @@schema("public")
}

model ProfileCategories {
  id        Int      @id @default(autoincrement())
  profile_id Int
  category_id Int
  created_at DateTime @default(now())
  profile  Profiles   @relation(fields: [profile_id], references: [id])
  category Categories @relation(fields: [category_id], references: [id])

  @@map("Profile_Categories")
  @@schema("public")
}

model StoryCategories {
  id        Int      @id @default(autoincrement())
  story_id Int
  category_id Int
  created_at DateTime @default(now())
  story  Stories   @relation(fields: [story_id], references: [id])
  category Categories @relation(fields: [category_id], references: [id])

  @@map("Story_Categories")
  @@schema("public")
}

model StoryPages {
  id        Int      @id @default(autoincrement())
  page_number Int
  story_translation_id Int
  text_content String
  photo_url String?
  audio_url String?
  created_at DateTime @default(now())
  storyTranslation StoryTranslations @relation(fields: [story_translation_id], references: [id])

  @@map("Story_Pages")
  @@schema("public")
}

model StoryTranslations {
  id        Int      @id @default(autoincrement())
  story_id Int
  language_id Int
  title String
  description String?
  created_at DateTime @default(now())
  language Languages @relation(fields: [language_id], references: [id])
  story Stories @relation(fields: [story_id], references: [id])

  storyPages StoryPages[]

  @@map("Story_Translations")
  @@schema("public")
}

model CategoryTranslations {
  id        Int      @id @default(autoincrement())
  category_id Int
  language_id Int
  name String
  created_at DateTime @default(now())
  language Languages @relation(fields: [language_id], references: [id])
  category Categories @relation(fields: [category_id], references: [id])

  @@map("Category_Translations")
  @@schema("public")
}

model Playlists {
  id        Int      @id @default(autoincrement())
  profile_id Int
  name String
  created_at DateTime @default(now())
  profile Profiles @relation(fields: [profile_id], references: [id])
  playlistStories PlaylistStories[]

  @@map("Playlists")
  @@schema("public")
}

model PlaylistStories {
  id        Int      @id @default(autoincrement())
  playlist_id Int
  story_id Int
  order Int
  created_at DateTime @default(now())
  playlist Playlists @relation(fields: [playlist_id], references: [id])
  story Stories @relation(fields: [story_id], references: [id])

  @@unique([playlist_id, story_id])
  @@map("Playlist_Stories")
  @@schema("public")
}

model Favorites {
  id        Int      @id @default(autoincrement())
  profile_id Int
  story_id Int
  created_at DateTime @default(now())
  profile Profiles @relation(fields: [profile_id], references: [id])
  story Stories @relation(fields: [story_id], references: [id])

  @@map("Favorites")
  @@schema("public")
}
