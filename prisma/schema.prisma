generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model Books {
  id               Int               @id @default(autoincrement())
  photo_url        String?
  duration         Int?
  status           Boolean           @default(true)
  created_at       DateTime          @default(now())
  bookCategories   BookCategories[]
  bookTranslations BookTranslations[]
  playlistBooks    PlaylistBooks[]
  favorites        Favorites[]

  @@map("Books")
  @@schema("public")
}

model User {
  id              String     @id @db.Uuid
  email           String?
  phone           String?
  role            String?
  created_at      DateTime?
  updated_at      DateTime?
  last_sign_in_at DateTime?
  app_metadata    Json       @default("{}") @map("raw_app_meta_data")
  user_metadata   Json       @default("{}") @map("raw_user_meta_data")
  profiles        Profiles[]

  @@map("users")
  @@schema("auth")
}

model Profiles {
  id                Int                 @id @default(autoincrement())
  user_id           String              @db.Uuid
  name              String
  date_of_birth     DateTime?           @db.Date
  gender            Boolean
  photo_url         String?
  created_at        DateTime            @default(now())
  user              User                @relation(fields: [user_id], references: [id])
  profileCategories ProfileCategories[]
  playlists         Playlists[]
  favorites         Favorites[]

  @@map("Profiles")
  @@schema("public")
}

model Categories {
  id                   Int                    @id @default(autoincrement())
  photo_url            String?
  status               Boolean                @default(true)
  created_at           DateTime               @default(now())
  profileCategories    ProfileCategories[]
  bookCategories       BookCategories[]
  categoryTranslations CategoryTranslations[]

  @@map("Categories")
  @@schema("public")
}

model Languages {
  id                   Int                    @id @default(autoincrement())
  name                 String
  country_code         String
  created_at           DateTime               @default(now())
  bookTranslations     BookTranslations[]
  categoryTranslations CategoryTranslations[]

  @@map("Languages")
  @@schema("public")
}

model ProfileCategories {
  id          Int        @id @default(autoincrement())
  profile_id  Int
  category_id Int
  created_at  DateTime   @default(now())
  profile     Profiles   @relation(fields: [profile_id], references: [id])
  category    Categories @relation(fields: [category_id], references: [id])

  @@map("Profile_Categories")
  @@schema("public")
}

model BookCategories {
  id          Int        @id @default(autoincrement())
  book_id     Int
  category_id Int
  created_at  DateTime   @default(now())
  book        Books      @relation(fields: [book_id], references: [id])
  category    Categories @relation(fields: [category_id], references: [id])

  @@map("Book_Categories")
  @@schema("public")
}

model BookPages {
  id                   Int              @id @default(autoincrement())
  page_number          Int
  book_translation_id  Int
  text_content         String
  photo_url            String?
  audio_url            String?
  created_at           DateTime         @default(now())
  bookTranslation      BookTranslations @relation(fields: [book_translation_id], references: [id])

  @@map("Book_Pages")
  @@schema("public")
}

model BookTranslations {
  id          Int       @id @default(autoincrement())
  book_id     Int
  language_id Int
  title       String
  description String?
  created_at  DateTime  @default(now())
  language    Languages @relation(fields: [language_id], references: [id])
  book        Books     @relation(fields: [book_id], references: [id])
  bookPages   BookPages[]

  @@map("Book_Translations")
  @@schema("public")
}

model CategoryTranslations {
  id          Int        @id @default(autoincrement())
  category_id Int
  language_id Int
  name        String
  created_at  DateTime   @default(now())
  language    Languages  @relation(fields: [language_id], references: [id])
  category    Categories @relation(fields: [category_id], references: [id])

  @@map("Category_Translations")
  @@schema("public")
}

model Playlists {
  id            Int             @id @default(autoincrement())
  profile_id    Int
  name          String
  created_at    DateTime        @default(now())
  profile       Profiles        @relation(fields: [profile_id], references: [id])
  playlistBooks PlaylistBooks[]

  @@map("Playlists")
  @@schema("public")
}

model PlaylistBooks {
  id          Int      @id @default(autoincrement())
  playlist_id Int
  book_id     Int
  order       Int
  created_at  DateTime @default(now())
  playlist    Playlists @relation(fields: [playlist_id], references: [id])
  book        Books    @relation(fields: [book_id], references: [id])

  @@unique([playlist_id, book_id])
  @@map("Playlist_Books")
  @@schema("public")
}

model Favorites {
  id         Int      @id @default(autoincrement())
  profile_id Int
  book_id    Int
  created_at DateTime @default(now())
  profile    Profiles @relation(fields: [profile_id], references: [id])
  book       Books    @relation(fields: [book_id], references: [id])

  @@map("Favorites")
  @@schema("public")
}
